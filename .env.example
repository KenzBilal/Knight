# ─── KNIGHT ENVIRONMENT VARIABLES ──────────────────────────────────────────────
# Copy this file to dashboard/.env.local and worker/.env
# Fill in your actual values before running.

# ─── DASHBOARD (.env.local) ───────────────────────────────────────────────────

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# LemonSqueezy (required for billing)
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Resend (required for emails)
RESEND_API_KEY=re_your_resend_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (optional — error tracking)
SENTRY_DSN=your_sentry_dsn

# ─── WORKER (.env) ────────────────────────────────────────────────────────────

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI Providers (required)
COHERE_API_KEY=your_cohere_api_key
GEMINI_API_KEY=your_gemini_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# Email (required)
RESEND_API_KEY=re_your_resend_api_key
RESEND_SENDER_EMAIL=hello@yourdomain.com

# Telegram (optional — for Telegram lead discovery)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
