{
  "name": "knight",
  "version": "1.0.0",
  "description": "Knight — AI-Powered B2B Sales Agent Control Center",
  "author": {
    "name": "Ken Bilal",
    "email": "ken@knight.app"
  },
  "homepage": "https://knight.app",
  "license": "MIT",
  "private": true,
  "type": "module",
  "bin": {
    "knight-admin": "./knight-admin.js"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "tsc -b && vite build && electron-builder",
    "build:linux": "tsc -b && vite build && electron-builder --linux",
    "build:mac": "tsc -b && vite build && electron-builder --mac",
    "build:win": "tsc -b && vite build && electron-builder --win",
    "icon": "node scripts/generate-icon.cjs",
    "lint": "oxlint",
    "preview": "vite preview",
    "cli": "node knight-admin.js",
    "postinstall": "node scripts/generate-icon.cjs && node scripts/generate-sounds.cjs"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.109.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.2.4",
    "cross-env": "^10.1.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "lucide-react": "^1.24.0",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.knight.desktop",
    "productName": "Knight",
    "copyright": "Copyright © 2026 Ken Bilal",
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "icon": "electron/icon.png",
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "electron/icons",
      "category": "Office",
      "desktop": {
        "Name": "Knight",
        "Comment": "AI-Powered B2B Sales Agent Control Center",
        "Keywords": "sales;crm;ai;automation;email;leads",
        "StartupNotify": "true"
      },
      "artifactName": "knight-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/icon.png",
      "category": "public.app-category.business",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "knight-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/icon.png",
      "artifactName": "knight-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Knight"
    }
  }
}
