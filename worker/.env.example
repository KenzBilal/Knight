# Knight Worker Environment Variables

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostHog (optional — enables events + feature flag kill switches)
POSTHOG_API_KEY=your-posthog-project-api-key

# AI Providers (optional — keys now managed via ai_keys table in DB)
# These env vars are fallbacks. DB keys take precedence.
COHERE_API_KEY=your-cohere-key
GEMINI_API_KEY=your-gemini-key
OPENROUTER_API_KEY=your-openrouter-key
GROQ_API_KEY=your-groq-key

# Email
RESEND_API_KEY=your-resend-key
RESEND_SENDER_EMAIL=hello@yourdomain.com

# Telegram (optional - for userbot)
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash
